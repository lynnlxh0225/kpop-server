# 复制本文件为 .env 后再修改
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
DB_PATH=./data/data.db
CORS_ORIGIN=*

# AI 服务（用于「整理消息」功能）
# 默认是 DeepSeek（最便宜的国内大模型，OpenAI 兼容协议）
# 去 https://platform.deepseek.com → API Keys 拿一个 key，填到下面
DEEPSEEK_API_KEY=
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat
# 想换通义/Kimi/智谱时改 BASE_URL + MODEL 即可（同样是 OpenAI 兼容）
# 通义：AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  AI_MODEL=qwen-plus
# Kimi：AI_BASE_URL=https://api.moonshot.cn/v1                          AI_MODEL=moonshot-v1-8k
# 智谱：AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4                AI_MODEL=glm-4-air

# 视觉模型（看截图识别聊天用），需要 base url 同时支持视觉模型
# 智谱：AI_VISION_MODEL=glm-4v-flash  （免费）或 glm-4.5v（付费但便宜）
# 通义：AI_VISION_MODEL=qwen-vl-plus
AI_VISION_MODEL=glm-4v-flash
